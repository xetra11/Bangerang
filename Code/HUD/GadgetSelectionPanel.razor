@using Sandbox;
@using Sandbox.UI;
@inherits Panel

<style>
  GadgetSelectionPanel {
    .gadget-bar {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 400px;
      height: 80px;
      background-color: grey;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 5px;
      margin-bottom: 15px;
    }

    .gadget-bar__slot {
      width: 50px;
      height: 50px;
      background-color: rgba(255, 255, 255, 0.5);
    }
  }

</style>
<root>
  <div class="gadget-bar">
    <div class="gadget-bar__slot"></div>
    <div class="gadget-bar__slot"></div>
    <div class="gadget-bar__slot"></div>
  </div>
</root>

