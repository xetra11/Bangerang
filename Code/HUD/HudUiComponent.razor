@using Sandbox;
@using Sandbox.Gadget
@using Sandbox.Greedy
@inherits PanelComponent
@implements IGreedyCollectEvent
@implements Sandbox.Gadget.IGadgetSelectedEvent

<root>
  <GreedyPanel Coins="@_coins"/>
  <GadgetSelectionPanel SelectedSlot="@_selectedSlot"></GadgetSelectionPanel>
</root>

@code
{
  private int _coins;
  private int _selectedSlot;

  protected override int BuildHash() => System.HashCode.Combine( _coins, _selectedSlot );

  public void OnGreedyCollect( int current )
  {
    Log.Info( "Greedy collected!" );
    _coins = current;
  }

  public void OnGadgetSelected( int index, Gadget gadget )
  {
    Log.Info( $"Selected slot: {index}" );
    _selectedSlot = index;
  }
}
