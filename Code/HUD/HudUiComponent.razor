@inherits PanelComponent
@using Sandbox.Gadget
@using Sandbox.Gadget.Development
@using Sandbox.Gadget.UI
@using Sandbox.Greedy
@implements Sandbox.Gadget.IGadgetSelectedEvent
@implements Sandbox.Greedy.IGreedyCollectEvent
@implements DeveloperInputSystem.IOpenGadgetDebuggerEvent

<root>
  <GreedyPanel Coins="@_coins"/>
  <GadgetSelectionPanel SelectedSlot="@_selectedSlot"></GadgetSelectionPanel>
  @if ( _showGadgetDebugger )
  {
    <GadgetSelectionDebugger GadgetHolder="@_gadgetHolder"></GadgetSelectionDebugger>
  }
</root>

@code
{
  private int _coins;
  private int _selectedSlot;
  private GadgetHolder _gadgetHolder;
  private bool _showGadgetDebugger;

  protected override int BuildHash() => System.HashCode.Combine( _coins, _selectedSlot, _gadgetHolder, _showGadgetDebugger);

  protected override void OnStart() => _gadgetHolder = Scene.GetSystem<GadgetSelectionSystem>().GadgetHolder;

  public void OnGreedyCollect( int current ) => _coins = current;
  public void OnGadgetSelected( int index, Gadget gadget ) => _selectedSlot = index;
  public void OnGadgetDebuggerToggle() => _showGadgetDebugger = !_showGadgetDebugger;
}
