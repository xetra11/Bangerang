@using Sandbox;
@using Sandbox.UI;
@inherits Panel

<style>
  MainMenuControlPanel {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-width: 0;
    min-height: 0;

    .buttons {
      display: flex;
      flex-direction: column;
      flex: 1 1 auto;
      min-width: 0;
      min-height: 0;
    }

    .buttons-image {
      flex: 1 1 auto;
      min-width: 0;
      min-height: 0;

      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
    }
  }

</style>

<root>
  <div class="buttons">
    <div class="buttons-image" style="background-image: url('@_buttonImageUrl');"></div>
    <div class="buttons-image" style="background-image: url('@_buttonImageUrl');"></div>
    <div class="buttons-image" style="background-image: url('@_buttonImageUrl');"></div>
  </div>
</root>

@code
{
  [Parameter] public Image Button { get; set; }

  private string _buttonImageUrl;

  protected override void OnParametersSet()
  {
    base.OnParametersSet();
    _buttonImageUrl = Button?.SourceFile.SimplifyPath() ?? "images/start_button.png";
  }

  protected override int BuildHash() => System.HashCode.Combine( Button );
}
