@using Sandbox;
@using Sandbox.UI;
@inherits Panel

<style>
  MainMenuControlPanel {
    pointer-events: all;

    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-width: 0;
    min-height: 0;

    .buttons {
      display: flex;
      flex-direction: column;
      flex: 1 1 auto;
      min-width: 0;
      min-height: 0;
      justify-content: center;
      align-items: center;
    }

    .buttons-image {
      flex: 0.1 1 auto;
      align-self: stretch;
      min-width: 0;
      min-height: 0;

      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
    }

    .spacer-x {
      height: 300px;
    }

    .spacer-s {
      height: 50px;
    }
  }

</style>
<root>
  <div class="spacer-x"></div>
  <div class="buttons">
    <div onmousedown="@StartGame" class="buttons-image" style="background-image: url('@_buttonImageUrl');"></div>
    <div class="spacer-s"></div>
    <div class="buttons-image" style="background-image: url('@_buttonImageUrl');"></div>
  </div>
</root>

@code
{
  [Parameter] public Image Button { get; set; }

  private void StartGame()
  {
    Log.Error( "Loading Scene" );
    Scene.LoadFromFile( "scenes/testzone.scene" );
  }

  private string _buttonImageUrl;

  protected override void OnParametersSet()
  {
    base.OnParametersSet();
    _buttonImageUrl = Button?.SourceFile.SimplifyPath() ?? "images/start_button.png";
    Mouse.Visibility = MouseVisibility.Visible;
  }

  protected override int BuildHash() => System.HashCode.Combine( Button );
}
