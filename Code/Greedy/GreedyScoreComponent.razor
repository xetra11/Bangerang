@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@implements IGreedyCollectEvent

<root>
  <GreedyPanel Coins="@Score"></GreedyPanel>
</root>

@code
{
  [Property] public int Score { get; set; }

  protected override int BuildHash() => System.HashCode.Combine( Score );
  public void OnGreedyCollect( int current )
  {
    Score = current;
  }
}
