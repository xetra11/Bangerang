@using Sandbox.UI;
@inherits Panel

<style>
  GadgetSelectionPanel {
    .gadget-bar {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 400px;
      height: 80px;
      background-color: grey;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 5px;
      margin-bottom: 15px;
    }

    .gadget-bar__slot {
      width: 50px;
      height: 50px;
      background-color: rgba(255, 255, 255, 0.5);
    }

    .gadget-bar__slot-selected {
      width: 50px;
      height: 50px;
      background-color: rgb(95 250 11 / 0.5);
    }
  }

</style>
<root>
  <div class="gadget-bar">
    @for ( var i = 0; i < _slots; i++ )
    {
      @if ( i == SelectedSlot )
      {
        <div class="gadget-bar__slot-selected"></div>
       }
      else
      {
        <div class="gadget-bar__slot"></div>
      }
    }
  </div>
</root>

@code
{
  [Parameter] public int SelectedSlot { get; set; }


  private int _slots = 3;
}
